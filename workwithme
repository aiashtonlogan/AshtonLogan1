<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8"/>
  <meta name="viewport" content="width=device-width, initial-scale=1.0"/>
  <title>Work With Me — Ashton Logan</title>
  <link rel="preconnect" href="https://fonts.googleapis.com">
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
  <link href="https://fonts.googleapis.com/css2?family=Bebas+Neue&family=Cormorant+Garamond:ital,wght@0,300;0,400;0,600;1,300;1,400&family=DM+Mono:wght@300;400&display=swap" rel="stylesheet">
  <style>
    *,*::before,*::after{box-sizing:border-box;margin:0;padding:0}
    :root{
      --black:#060606;--charcoal:#0e0e0e;--surface:#141414;--border:#1f1f1f;
      --muted:#2e2e2e;--text-dim:#505050;--text-mid:#8a8a8a;--text-main:#c8c8c8;
      --text-bright:#ebebeb;--accent:#b0b0b0;--accent-light:#d4d4d4;--accent-dim:#3a3a3a;
    }
    html{scroll-behavior:smooth}
    body{background:var(--black);color:var(--text-main);font-family:'Cormorant Garamond',serif;overflow-x:hidden;cursor:none}

    .cursor{position:fixed;width:8px;height:8px;background:var(--accent);border-radius:50%;pointer-events:none;z-index:9999;transform:translate(-50%,-50%)}
    .cursor-ring{position:fixed;width:32px;height:32px;border:1px solid rgba(176,176,176,0.35);border-radius:50%;pointer-events:none;z-index:9998;transition:width .2s,height .2s,border-color .2s;transform:translate(-50%,-50%)}
    body:has(a:hover) .cursor-ring,body:has(button:hover) .cursor-ring{width:48px;height:48px;border-color:var(--accent)}

    /* NAV */
    nav{position:fixed;top:0;left:0;right:0;z-index:100;display:flex;align-items:center;justify-content:space-between;padding:28px 60px;background:linear-gradient(to bottom,rgba(6,6,6,0.97),transparent)}
    .nav-logo{font-family:'Bebas Neue',sans-serif;font-size:1.4rem;letter-spacing:.18em;color:var(--text-bright);text-decoration:none}
    .nav-logo span{color:var(--accent)}
    .nav-back{font-family:'DM Mono',monospace;font-size:.65rem;letter-spacing:.2em;text-transform:uppercase;color:var(--text-dim);text-decoration:none;transition:color .3s;display:flex;align-items:center;gap:10px}
    .nav-back:hover{color:var(--accent)}
    .nav-back::before{content:'←'}

    /* HERO */
    #hero{position:relative;min-height:100vh;display:flex;flex-direction:column;justify-content:center;padding:140px 60px 100px;overflow:hidden}
    .hero-grain{position:absolute;inset:0;background-image:url("data:image/svg+xml,%3Csvg viewBox='0 0 256 256' xmlns='http://www.w3.org/2000/svg'%3E%3Cfilter id='n'%3E%3CfeTurbulence type='fractalNoise' baseFrequency='0.9' numOctaves='4' stitchTiles='stitch'/%3E%3C/filter%3E%3Crect width='100%25' height='100%25' filter='url(%23n)' opacity='0.04'/%3E%3C/svg%3E");background-size:200px;opacity:.5;pointer-events:none}
    .hero-line{position:absolute;top:0;right:240px;width:1px;height:100%;background:linear-gradient(to bottom,transparent,var(--border) 20%,var(--border) 80%,transparent);opacity:.4}
    .hero-eyebrow{font-family:'DM Mono',monospace;font-size:.65rem;letter-spacing:.3em;text-transform:uppercase;color:var(--accent);margin-bottom:24px;opacity:0;animation:fadeUp .8s ease .3s forwards;position:relative;z-index:2}
    .hero-heading{font-family:'Bebas Neue',sans-serif;font-size:clamp(64px,9vw,136px);line-height:.9;color:var(--text-bright);letter-spacing:.02em;opacity:0;animation:fadeUp .9s ease .5s forwards;position:relative;z-index:2}
    .hero-heading em{font-family:'Cormorant Garamond',serif;font-style:italic;font-weight:300;color:var(--accent);display:block}
    .hero-sub{margin-top:32px;font-family:'Cormorant Garamond',serif;font-style:italic;font-weight:300;font-size:clamp(18px,2vw,26px);color:var(--text-mid);max-width:600px;line-height:1.65;opacity:0;animation:fadeUp .9s ease .7s forwards;position:relative;z-index:2}
    .hero-cta{margin-top:52px;display:flex;gap:20px;align-items:center;opacity:0;animation:fadeUp .9s ease .9s forwards;position:relative;z-index:2;flex-wrap:wrap}
    .btn-primary{display:inline-flex;align-items:center;padding:16px 40px;background:var(--accent);color:var(--black);font-family:'DM Mono',monospace;font-size:.7rem;letter-spacing:.2em;text-transform:uppercase;text-decoration:none;transition:background .3s,transform .2s}
    .btn-primary:hover{background:var(--accent-light);transform:translateY(-2px)}
    .btn-ghost{display:inline-flex;align-items:center;padding:16px 40px;border:1px solid var(--border);color:var(--text-mid);font-family:'DM Mono',monospace;font-size:.7rem;letter-spacing:.2em;text-transform:uppercase;text-decoration:none;transition:border-color .3s,color .3s}
    .btn-ghost:hover{border-color:var(--accent);color:var(--accent)}
    .hero-number{position:absolute;top:50%;right:40px;transform:translateY(-50%);font-family:'Bebas Neue',sans-serif;font-size:clamp(200px,28vw,380px);color:transparent;-webkit-text-stroke:1px rgba(176,176,176,0.05);line-height:1;user-select:none;pointer-events:none;z-index:1}

    /* SECTION BASE */
    section{padding:120px 60px}
    .section-label{font-family:'DM Mono',monospace;font-size:.6rem;letter-spacing:.35em;text-transform:uppercase;color:var(--accent);margin-bottom:16px;display:flex;align-items:center;gap:16px}
    .section-label::after{content:'';display:block;width:40px;height:1px;background:var(--accent-dim)}
    .section-heading{font-family:'Bebas Neue',sans-serif;font-size:clamp(44px,5vw,68px);line-height:1;color:var(--text-bright);margin-bottom:16px}
    .section-heading em{font-family:'Cormorant Garamond',serif;font-style:italic;font-weight:300;color:var(--accent)}

    /* WHY ME */
    #why{background:var(--charcoal)}
    .why-grid{display:grid;grid-template-columns:1fr 1fr;gap:80px;align-items:start;max-width:1100px}
    .why-body p{font-size:1.05rem;font-weight:300;line-height:1.85;color:var(--text-mid);margin-bottom:20px}
    .why-body p strong{color:var(--text-bright);font-weight:600}
    .why-stats{display:grid;grid-template-columns:1fr 1fr;gap:2px;margin-top:8px}
    .why-stat{background:var(--surface);padding:28px 24px;border-bottom:2px solid transparent;transition:border-color .3s}
    .why-stat:hover{border-color:var(--accent)}
    .why-stat-num{font-family:'Bebas Neue',sans-serif;font-size:2.8rem;color:var(--accent);line-height:1;margin-bottom:6px}
    .why-stat-label{font-family:'DM Mono',monospace;font-size:.6rem;letter-spacing:.2em;text-transform:uppercase;color:var(--text-dim)}

    /* WHAT I OFFER */
    #offer{background:var(--black)}
    .offer-grid{display:grid;grid-template-columns:repeat(3,1fr);gap:2px;margin-top:60px}
    .offer-card{background:var(--surface);padding:44px 36px;position:relative;overflow:hidden;transition:background .3s}
    .offer-card::before{content:'';position:absolute;top:0;left:0;width:2px;height:0;background:var(--accent);transition:height .4s ease}
    .offer-card:hover::before{height:100%}
    .offer-card:hover{background:#181818}
    .offer-num{font-family:'Bebas Neue',sans-serif;font-size:3.5rem;color:rgba(176,176,176,0.06);line-height:1;margin-bottom:20px}
    .offer-title{font-family:'Bebas Neue',sans-serif;font-size:1.4rem;letter-spacing:.05em;color:var(--text-bright);margin-bottom:14px}
    .offer-body{font-size:.95rem;font-weight:300;line-height:1.8;color:var(--text-dim)}

    /* HOW IT WORKS */
    #process{background:var(--charcoal)}
    .process-steps{display:grid;grid-template-columns:repeat(4,1fr);gap:2px;margin-top:60px}
    .step{background:var(--surface);padding:40px 32px;position:relative}
    .step-num{font-family:'Bebas Neue',sans-serif;font-size:5rem;color:rgba(176,176,176,0.05);line-height:1;margin-bottom:16px}
    .step-title{font-family:'Bebas Neue',sans-serif;font-size:1.2rem;letter-spacing:.05em;color:var(--text-bright);margin-bottom:12px}
    .step-body{font-size:.9rem;font-weight:300;line-height:1.8;color:var(--text-dim)}
    .step-connector{position:absolute;top:40px;right:-1px;width:2px;height:40px;background:var(--accent-dim)}

    /* PROOF */
    #proof{background:var(--black);text-align:center;padding:100px 60px}
    .proof-quote{font-family:'Cormorant Garamond',serif;font-style:italic;font-weight:300;font-size:clamp(24px,3vw,44px);color:var(--text-bright);max-width:780px;margin:0 auto 24px;line-height:1.45}
    .proof-quote span{color:var(--accent-light)}
    .proof-sub{font-family:'DM Mono',monospace;font-size:.6rem;letter-spacing:.3em;text-transform:uppercase;color:var(--text-dim);margin-bottom:60px}
    .proof-tags{display:flex;flex-wrap:wrap;gap:10px;justify-content:center;margin-top:40px}
    .proof-tag{padding:10px 22px;border:1px solid var(--border);font-family:'DM Mono',monospace;font-size:.6rem;letter-spacing:.15em;text-transform:uppercase;color:var(--text-dim)}

    /* CTA */
    #contact{background:var(--charcoal);padding:120px 60px;display:flex;align-items:center;justify-content:space-between;flex-wrap:wrap;gap:60px;border-top:1px solid var(--border)}
    .contact-left h2{font-family:'Bebas Neue',sans-serif;font-size:clamp(44px,5vw,72px);line-height:1;color:var(--text-bright);margin-bottom:16px}
    .contact-left h2 em{font-family:'Cormorant Garamond',serif;font-style:italic;font-weight:300;color:var(--accent)}
    .contact-left p{font-size:1rem;font-weight:300;color:var(--text-dim);max-width:440px;line-height:1.7}
    .contact-right{display:flex;flex-direction:column;gap:16px;min-width:280px}
    .contact-item{display:flex;align-items:center;gap:16px;text-decoration:none;color:var(--text-mid);font-family:'DM Mono',monospace;font-size:.7rem;letter-spacing:.15em;transition:color .3s}
    .contact-item:hover{color:var(--accent-light)}
    .contact-icon{width:44px;height:44px;border:1px solid var(--border);display:flex;align-items:center;justify-content:center;transition:border-color .3s;flex-shrink:0}
    .contact-item:hover .contact-icon{border-color:var(--accent)}
    .contact-icon svg{width:16px;height:16px;fill:currentColor}

    footer{background:var(--black);padding:40px 60px;display:flex;justify-content:space-between;align-items:center;border-top:1px solid var(--border)}
    .footer-logo{font-family:'Bebas Neue',sans-serif;font-size:1.1rem;letter-spacing:.15em;color:var(--text-dim)}
    .footer-logo span{color:var(--accent)}
    .footer-copy{font-family:'DM Mono',monospace;font-size:.55rem;letter-spacing:.2em;color:var(--muted);text-transform:uppercase}

    @keyframes fadeUp{from{opacity:0;transform:translateY(24px)}to{opacity:1;transform:translateY(0)}}
    .reveal{opacity:0;transform:translateY(30px);transition:opacity .8s ease,transform .8s ease}
    .reveal.visible{opacity:1;transform:translateY(0)}

    @media(max-width:900px){
      nav{padding:24px 28px}
      section,#contact{padding:80px 28px}
      #hero{padding:120px 28px 80px}
      .why-grid{grid-template-columns:1fr;gap:48px}
      .offer-grid{grid-template-columns:1fr}
      .process-steps{grid-template-columns:1fr 1fr}
      #contact{flex-direction:column}
      footer{padding:32px 28px;flex-direction:column;gap:16px;text-align:center}
      .hero-number{display:none}
    }
  </style>
</head>
<body>

  <div class="cursor" id="cursor"></div>
